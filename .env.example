# Supabase (dashboard app + edge functions)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Widget (embedded in widget.js bundle at build time)
VITE_WIDGET_SUPABASE_URL=https://your-project.supabase.co
VITE_WIDGET_SUPABASE_ANON_KEY=your-anon-key
VITE_WIDGET_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1

# Edge Function secrets (set via: supabase secrets set KEY=value)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token
WHATSAPP_TOKEN=your-meta-permanent-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
META_VERIFY_TOKEN=your-custom-verify-token
RESEND_API_KEY=your-resend-api-key
OPENAI_API_KEY=sk-your-openai-api-key
